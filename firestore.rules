rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Helper to check if user is staff
    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // Helper to check if user is admin or staff
    function isStaffOrAdmin() {
      return isAdmin() || isStaff();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaffOrAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Referrals
    match /referrals/{referralId} {
      // Anyone can submit a referral
      allow create: if true;
      // Staff/Admins can read and update
      allow read, update: if isStaffOrAdmin();
      // Only admins can delete referrals
      allow delete: if isAdmin();
    }

    // Residents, Beds, Tasks
    match /residents/{document} {
      allow read, create, update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }

    match /beds/{document} {
      allow read, create, update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }

    match /tasks/{document} {
      allow read, create, update: if isStaffOrAdmin();
      allow delete: if isAdmin();
    }
    
    // Default fallback rules
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
